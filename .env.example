# n8n 基本設定
N8N_HOST=localhost           # n8nサーバーのホスト（例: localhost）
N8N_PORT=5678                # n8nサーバーのポート（例: 5678）
N8N_PROTOCOL=http            # http または https
GENERIC_TIMEZONE=Asia/Tokyo  # タイムゾーン設定
N8N_ENCRYPTION_KEY=your_random_32_char_string  # データ暗号化キー

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# OpenWeatherMap API
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here